#!hexa strict
// hexa-matter/tests/test_selftest.hexa — CLI selftest equivalent.
//
// Referenced by hexa.toml [test] files list. Mirrors the production
// `cli/hexa-matter.hexa selftest` 17-verb spec-doc presence check (the
// CLI dispatcher's canonical PASS path) using the same VERBS registry,
// driven independently from this test file.
//
// Why not exec the CLI? The hexa 0.1.0-dispatch runtime does not
// forward args to scripts invoked via `hexa run <script> <subcmd>`,
// so we replicate the spec-presence logic here for the same coverage.
// (See verify/spec_presence.hexa for the verify-script-shaped check;
// this test exists to satisfy hexa.toml's [test] manifest.)

let HOME = env("HOME")
let HEXA_MATTER_ROOT_ENV = env("HEXA_MATTER_ROOT")

fn shq(s: str) -> str {
    return "'" + s.replace("'", "'\\''") + "'"
}

fn _resolve_root() -> str {
    if HEXA_MATTER_ROOT_ENV.len() > 0 { return HEXA_MATTER_ROOT_ENV }
    let oldpwd = env("OLDPWD")
    if oldpwd.len() > 0 {
        let t = exec("[ -f " + shq(oldpwd) + "/hexa.toml ] && echo y || echo n").trim()
        if t == "y" { return oldpwd }
    }
    let pwd = env("PWD")
    if pwd.len() > 0 {
        let t = exec("[ -f " + shq(pwd) + "/hexa.toml ] && echo y || echo n").trim()
        if t == "y" { return pwd }
    }
    return HOME + "/core/hexa-matter"
}

fn _file_exists(p: str) -> bool {
    let r = exec("[ -f " + shq(p) + " ] && echo yes || echo no").trim()
    return r == "yes"
}

// Mirror of cli/hexa-matter.hexa VERBS table.
let VERBS = [
    ["ceramics",      "ceramics",      "ceramics.md"],
    ["concrete",      "concrete",      "concrete.md"],
    ["concrete_tech", "concrete_tech", "concrete-technology.md"],
    ["glass",         "glass",         "hexa-glass.md"],
    ["silicon",       "silicon",       "silicon.md"],
    ["aramid",        "aramid",        "aramid.md"],
    ["epoxy",         "epoxy",         "epoxy.md"],
    ["nylon",         "nylon",         "nylon.md"],
    ["pet_film",      "pet_film",      "pet-film.md"],
    ["tire_cord",     "tire_cord",     "tire-cord.md"],
    ["fabric",        "fabric",        "hexa-fabric.md"],
    ["paper",         "paper",         "paper.md"],
    ["gemology",      "gemology",      "gemology.md"],
    ["metallurgy",    "metallurgy",    "swordsmithing.md"],
    ["synthesis",     "synthesis",     "material-synthesis.md"],
    ["recycle_n6",    "recycle_n6",    "hexa-recycle.md"],
    ["recycling",     "recycling",     "recycling.md"],
]

fn main() {
    let root = _resolve_root()
    println("hexa-matter/tests/test_selftest — 17-verb spec doc presence")
    println("  root: " + root)
    println("")

    let cli = root + "/cli/hexa-matter.hexa"
    if _file_exists(cli) == false {
        println("  [FAIL] CLI entry missing: " + cli)
        println("__HEXA_MATTER_TEST_SELFTEST__ FAIL")
        exit(1)
    }
    println("  [PASS] CLI entry present: cli/hexa-matter.hexa")

    let mut count = 0
    let mut bad = 0
    for row in VERBS {
        let verb = row[0]
        let p = root + "/" + row[1] + "/" + row[2]
        if _file_exists(p) {
            count = count + 1
        } else {
            println("  [FAIL] " + verb + " (missing: " + p + ")")
            bad = bad + 1
        }
    }
    println("  verbs_present = " + str(count) + " / 17")

    if count == 17 && bad == 0 {
        println("  [PASS] 17/17 verb spec docs reachable")
        println("__HEXA_MATTER_TEST_SELFTEST__ PASS")
        return
    }
    println("__HEXA_MATTER_TEST_SELFTEST__ FAIL")
    exit(1)
}
